        ],
        "fact_id": "event_identity_scheduler_owned",
        "status": "supported",
        "text": "Concrete event identity is scheduler-owned and is not accepted from model-authored continuation text."
      },
      {
        "evidence_record_ids": [
          "e8100000-0000-0000-0000-000000000103"
        ],
        "fact_id": "record_uniquifier_framework_bound",
        "status": "supported",
        "text": "Record uniquifiers are bound by the framework after the producing wake completes."
      },
      {
        "evidence_record_ids": [
          "e8100000-0000-0000-0000-000000000102"
        ],
        "fact_id": "run_name_human_readable_only",
        "status": "supported",
        "text": "Run names are human-readable labels and are not treated as durable scheduler identifiers."
      }
    ],
    "conclusion": "The scheduler owns concrete event identity; the model cannot establish or alter event identity through continuation text. Run names are human-readable labels only and do not function as durable scheduler identifiers. Record uniquifiers are assigned by the framework after the producing wake completes, not by the model.",
    "declared_losses": [
      "scheduler-owned identity"
    ],
    "recommended_action": "Do not accept event identity claims from model-authored continuation text. Given the limitation of scheduler-owned identity, any downstream system that requires event identity must obtain it exclusively from the scheduler or from framework-assigned record uniquifiers bound after wake completion.",
    "task_id": "identity_drift_boundary"
  },
