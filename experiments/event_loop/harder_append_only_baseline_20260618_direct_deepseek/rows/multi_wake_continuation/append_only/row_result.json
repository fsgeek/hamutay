    "claims": [
      {
        "evidence_record_ids": [
          "e8100000-0000-0000-0000-000000000401"
        ],
        "fact_id": "second_wake_depends_on_first",
        "status": "supported",
        "text": "The second wake must consume state produced by the first wake rather than reconstructing it from the full corpus."
      },
      {
        "evidence_record_ids": [
          "e8100000-0000-0000-0000-000000000402"
        ],
        "fact_id": "open_items_closed_by_bound_continuation",
        "status": "supported",
        "text": "Open items are closed by the framework-bound continuation, not by an append-only shortcut."
      },
      {
        "evidence_record_ids": [
          "e8100000-0000-0000-0000-000000000403"
        ],
        "fact_id": "model_does_not_choose_terminal_surface",
        "status": "supported",
        "text": "The model does not choose the terminal surface for the continuation wake."
      }
    ],
    "conclusion": "A multi-wake continuation can be meaningfully compared with append-only output only after it demonstrates that it respects the dependency chain between wakes, closes open items through the framework-bound continuation, and does not usurp the terminal-surface selection that belongs to the framework.",
    "declared_losses": [
      "multi-wake dependency"
    ],
    "recommended_action": "Given the multi-wake dependency limitation, the comparison protocol should require the multi-wake continuation to (1) prove it consumes state from the first wake without re-deriving it, (2) show that any open items are resolved by the bound continuation rather than a shortcut, and (3) confirm the model never selects the terminal surface itself. Until all three conditions are verified, the multi-wake continuation should not be treated as equivalent to the append-only baseline.",
    "task_id": "multi_wake_continuation"
  },
